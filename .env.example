# ============================================================
# .env.example — AI Resume Analyzer / AI Career Intelligence Platform
# Copie para .env e ajuste os valores conforme necessário.
# Nunca commite o arquivo .env real.
# ============================================================

# --- Backend (FastAPI) ---
# development libera CORS para qualquer origem; qualquer outro valor
# restringe ao FRONTEND_ORIGIN abaixo.
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173

# --- PostgreSQL ---
# Credenciais de desenvolvimento apenas. Nunca usar senha de produção aqui.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_resume_analyzer

# DATABASE_URL: usada por SQLAlchemy/Alembic (SPEC 0004) para persistir o
# resultado de cada análise (hash do PDF/vaga, score, skills, insights,
# recomendações — nunca o PDF ou o texto bruto). Dentro do docker-compose,
# "postgres" é o nome do serviço; rodando o backend manualmente (fora do
# Docker), troque o host para "localhost".
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_resume_analyzer

# ENABLE_HISTORY_API (SPEC 0005): liga os endpoints de leitura do histórico
# (GET /api/v1/analyses e GET /api/v1/analyses/{id}). Desligada por padrão
# ("false") porque, sem autenticação, o histórico é global e anônimo —
# qualquer cliente da API veria análises de qualquer pessoa. Mantenha
# "false" em deploy público até existir autenticação/sessão. Em testes e
# CI, use "true".
ENABLE_HISTORY_API=false

# ENABLE_ANALYTICS_API (SPEC 0006): liga os endpoints de analytics agregada
# (GET /api/v1/analytics/summary, /skills, /timeline). Flag separada de
# ENABLE_HISTORY_API porque expõe apenas números agregados (médias,
# contagens, rankings), nunca um registro individual — mas ainda assim,
# sem autenticação, os analytics são globais/anônimos. Desligada por
# padrão ("false"); mantenha "false" em deploy público até existir
# autenticação/sessão. Em testes e CI, use "true".
ENABLE_ANALYTICS_API=false

# ENABLE_SEMANTIC_MATCHING (SPEC 0011): liga o enriquecimento semântico via
# embeddings (semantic_score, hybrid_score, semantic_matches na resposta de
# POST /analyze). Desligada por padrão ("false"): diferente das flags acima,
# o motivo não é autenticação — é que a dependência (`sentence-transformers`,
# que traz `torch` transitivamente) fica só em `requirements-dev.txt`, nunca
# na imagem de produção. Mantenha "false" em deploy público. Para testar
# localmente: `pip install -r requirements-dev.txt` e ligue "true" aqui.
ENABLE_SEMANTIC_MATCHING=false

# ENABLE_LLM_FEEDBACK (SPEC 0014): liga o feedback textual assistido por um
# LLM open-source local via Ollama (llm_summary, llm_improvement_plan,
# llm_study_suggestions, llm_resume_tips na resposta de POST /analyze). O
# LLM só explica o resultado já calculado — nunca decide score ou matching.
# Desligada por padrão ("false"): diferente das flags acima, o motivo não é
# autenticação — é que Ollama é um processo externo que não existe no
# ambiente de deploy atual (Render). Mantenha "false" em produção. Para
# testar localmente: instale o Ollama (https://ollama.com/), rode
# `ollama pull llama3.1`, e ligue "true" aqui.
ENABLE_LLM_FEEDBACK=false

# Provider de LLM ativo (SPEC 0014) — apenas "ollama" é suportado.
LLM_PROVIDER=ollama

# URL do Ollama local e modelo a usar. Irrelevantes se ENABLE_LLM_FEEDBACK
# estiver "false".
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Frontend (Vite) ---
# URL que o navegador usa para chamar o backend a partir do host.
VITE_API_BASE_URL=http://localhost:8000
